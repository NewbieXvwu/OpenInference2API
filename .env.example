# OpenInference2API Environment Variables
# Copy this file to .env and fill in the values

# ===========================================
# REQUIRED - These must be set
# ===========================================

# VibeDuel API Key (from https://vibeduel.ai/keys)
VIBEDUEL_API_KEY=your_vibeduel_api_key_here

# API Key that downstream clients will use to authenticate
DOWNSTREAM_API_KEY=your_downstream_api_key_here

# ===========================================
# OPTIONAL - These have sensible defaults
# ===========================================

# Server configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# VibeDuel upstream URL
VIBEDUEL_BASE_URL=https://api.vibeduel.ai/v1

# Auto-refill settings
AUTO_REFILL_ENABLED=true
AUTO_REFILL_THRESHOLD=60
AUTO_REFILL_INTERVAL_MS=30000
AUTO_REFILL_MAX_PER_SESSION=5

# Threshold: Trigger auto-refill when credits fall below this value (default: 60)
AUTO_REFILL_THRESHOLD=60

# Path to config.yaml (default: ./config.yaml)
CONFIG_PATH=./config.yaml
